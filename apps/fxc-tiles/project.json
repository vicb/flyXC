{
  "name": "fxc-tiles",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "includedScripts": [],
  "sourceRoot": "apps/fxc-tiles/src",
  "projectType": "application",
  "tags": [],
  "targets": {
    "build": {
      "outputs": ["{projectRoot}/{options.outDir}", "{projectRoot}/dist"],
      "defaultConfiguration": "production",
      "options": {
        "outDir": "./dist"
      },
      "configurations": {
        "development": {
          "mode": "development"
        },
        "production": {
          "mode": "production"
        }
      }
    },
    "serve": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npx servez -p 8084 -q apps/fxc-tiles/assets/tiles"
      }
    }
  }
}
